<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">


  <!--
  ╔═════════════════════════════════════════════════════════════════════╗
  ║           MAPPING JOINT <-> DYNAMIXEL  (transmission matrix)        ║
  ║  Index   │ Nome joint          │ gpio name              │ ID        ║
  ║──────────┼─────────────────────┼────────────────────────┼───────────║
  ║  0       │ waist_yaw_joint     │ waist_yaw_dxl          │  1        ║
  ║  1       │ neck_yaw_joint      │ neck_yaw_dxl           │  2        ║
  ║  2       │ neck_pitch_joint    │ neck_pitch_dxl         │  3        ║
  ║  3       │ l_arm_joint1        │ l_arm_joint1_dxl       │ 11        ║
  ║  4       │ l_arm_joint2        │ l_arm_joint2_dxl       │ 12        ║
  ║  5       │ l_arm_joint3        │ l_arm_joint3_dxl       │ 13        ║
  ║  6       │ l_arm_joint4        │ l_arm_joint4_dxl       │ 14        ║
  ║  7       │ l_arm_joint5        │ l_arm_joint5_dxl       │ 15        ║
  ║  8       │ l_arm_joint6        │ l_arm_joint6_dxl       │ 16        ║
  ║  9       │ l_gripper_joint     │ l_gripper_dxl          │ 17        ║
  ║ 10       │ r_arm_joint1        │ r_arm_joint1_dxl       │ 21        ║
  ║ 11       │ r_arm_joint2        │ r_arm_joint2_dxl       │ 22        ║
  ║ 12       │ r_arm_joint3        │ r_arm_joint3_dxl       │ 23        ║
  ║ 13       │ r_arm_joint4        │ r_arm_joint4_dxl       │ 24        ║
  ║ 14       │ r_arm_joint5        │ r_arm_joint5_dxl       │ 25        ║
  ║ 15       │ r_arm_joint6        │ r_arm_joint6_dxl       │ 26        ║
  ║ 16       │ r_gripper_joint     │ r_gripper_dxl          │ 27        ║
  ╚═════════════════════════════════════════════════════════════════════╝

  NOTA: i gpio devono essere dichiarati nello STESSO ORDINE degli indici
  della tabella, perché la transmission matrix identità mappa joint[i] <-> gpio[i].
  NON riordinare i blocchi gpio senza aggiornare anche la tabella sopra.

  NOTA: Present Current è commentato intenzionalmente su tutti i motori
  tranne dxl1 (torso). Sarà abilitato in futuro per la gravity compensation.

  Drive Mode: 0 = normale (CW), 1 = invertito (CCW)
  -->

  <!-- Crea la matrice identità NxN Dynamixel -->
  <xacro:macro name="identity_matrix_csv" params="n">
    ${', '.join([
      '1' if i == j else '0'
      for i in python.range(int(n))
      for j in python.range(int(n))
    ])}
  </xacro:macro>

<xacro:macro name="rakuda_ros2_control_settings" params="dof use_mock_hardware:=false mock_sensor_commands:=false">

  <ros2_control name="RakudaSystem" type="system">
    <hardware>

      <xacro:if value="${use_mock_hardware}">
        <plugin>mock_components/GenericSystem</plugin>
        <param name="mock_sensor_commands">${mock_sensor_commands}</param>
      </xacro:if>

      <xacro:unless value="${use_mock_hardware}">
        <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>

        <param name="port_name">/dev/ttyU2D2</param>
        <param name="baud_rate">2000000</param>
        <param name="error_timeout_ms">500</param>

        <param name="dynamixel_model_folder">/param/dxl_model</param>

        <param name="number_of_joints">${dof}</param>
        <param name="number_of_transmissions">${dof}</param>

        <param name="transmission_to_joint_matrix"><xacro:identity_matrix_csv n="${dof}"/></param>
        <param name="joint_to_transmission_matrix"><xacro:identity_matrix_csv n="${dof}"/></param>

        <param name="disable_torque_at_init">true</param>

        <param name="dynamixel_state_pub_msg_name">dynamixel_hardware_interface/dxl_state</param>
        <param name="get_dynamixel_data_srv_name">dynamixel_hardware_interface/get_dxl_data</param>
        <param name="set_dynamixel_data_srv_name">dynamixel_hardware_interface/set_dxl_data</param>
        <param name="reboot_dxl_srv_name">dynamixel_hardware_interface/reboot_dxl</param>
        <param name="set_dxl_torque_srv_name">dynamixel_hardware_interface/set_dxl_torque</param>

        </xacro:unless>
      </hardware>

<!-- JOINT INTERFACE (ros2_control / moveit)-->

      <!-- index 0 -->
      <joint name="waist_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 1 -->
      <joint name="neck_yaw_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 2 -->
      <joint name="neck_pitch_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 3 -->
      <joint name="l_arm_joint1">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 4 -->
      <joint name="l_arm_joint2">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 5 -->
      <joint name="l_arm_joint3">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 6 -->
      <joint name="l_arm_joint4">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 7 -->
      <joint name="l_arm_joint5">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 8 -->
      <joint name="l_arm_joint6">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 9 -->
      <joint name="l_gripper_joint">
      	<command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 10 -->
      <joint name="r_arm_joint1">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 11 -->
      <joint name="r_arm_joint2">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 12 -->
      <joint name="r_arm_joint3">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 13 -->
      <joint name="r_arm_joint4">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 14 -->
      <joint name="r_arm_joint5">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 15 -->
      <joint name="r_arm_joint6">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- index 16 -->
      <joint name="r_gripper_joint">
      	<command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>


      <xacro:unless value="${use_mock_hardware}">
<!-- GPIO /Dynamixel Hardware -->

<!--TORSO -->

      <!-- index 0 | waist_yaw_joint | ID 1 -->
      <gpio name="waist_yaw_dxl">
        <param name="type">dxl</param>
        <param name="ID">1</param>
        <command_interface name="Goal Position"/>	
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <state_interface name="Present Current"/>
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">40</param>
        <param name="Profile Acceleration">20</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

<!--HEAD -->

      <!-- index 1 | neck_yaw_joint | ID 2 -->
      <gpio name="neck_yaw_dxl">
        <param name="type">dxl</param>
        <param name="ID">2</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">360</param>
        <param name="Profile Acceleration">180</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 2 | neck_pitch_joint | ID 3 | Drive Mode 1 = invertito -->
      <gpio name="neck_pitch_dxl">
        <param name="type">dxl</param>
        <param name="ID">3</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">360</param>
        <param name="Profile Acceleration">180</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">1</param>
      </gpio>

<!--LEFT ARM -->

      <!-- index 3 | l_arm_joint1 | ID 11 -->
      <gpio name="l_arm_joint1_dxl">
        <param name="type">dxl</param>
        <param name="ID">11</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 4 | l_arm_joint2 | ID 12 | Drive Mode 1 = invertito -->
      <gpio name="l_arm_joint2_dxl">
        <param name="type">dxl</param>
        <param name="ID">12</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">1</param>
      </gpio>

      <!-- index 5 | l_arm_joint3 | ID 13 -->
      <gpio name="l_arm_joint3_dxl">
        <param name="type">dxl</param>
        <param name="ID">13</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 6 | l_arm_joint4 | ID 14 -->
      <gpio name="l_arm_joint4_dxl">
        <param name="type">dxl</param>
        <param name="ID">14</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 7 | l_arm_joint5 | ID 15 -->
      <gpio name="l_arm_joint5_dxl">
        <param name="type">dxl</param>
        <param name="ID">15</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 8 | l_arm_joint6 | ID 16 -->
      <gpio name="l_arm_joint6_dxl">
        <param name="type">dxl</param>
        <param name="ID">16</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 9 | l_gripper_joint | ID 17 -->
      <gpio name="l_gripper_dxl">
        <param name="type">dxl</param>
        <param name="ID">17</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">100</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

<!--RIGHT ARM -->

      <!-- index 10 | r_arm_joint1 | ID 21 -->
      <gpio name="r_arm_joint1_dxl">
        <param name="type">dxl</param>
        <param name="ID">21</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 11 | r_arm_joint2 | ID 22 | Drive Mode 1 = invertito -->
      <gpio name="r_arm_joint2_dxl">
        <param name="type">dxl</param>
        <param name="ID">22</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">1</param>
      </gpio>

      <!-- index 12 | r_arm_joint3 | ID 23 -->
      <gpio name="r_arm_joint3_dxl">
        <param name="type">dxl</param>
        <param name="ID">23</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 13 | r_arm_joint4 | ID 24 -->
      <gpio name="r_arm_joint4_dxl">
        <param name="type">dxl</param>
        <param name="ID">24</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 14 | r_arm_joint5 | ID 25 -->
      <gpio name="r_arm_joint5_dxl">
        <param name="type">dxl</param>
        <param name="ID">25</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 15 | r_arm_joint6 | ID 26 -->
      <gpio name="r_arm_joint6_dxl">
        <param name="type">dxl</param>
        <param name="ID">26</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">80</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>

      <!-- index 16 | r_gripper_joint | ID 27 -->
      <gpio name="r_gripper_dxl">
        <param name="type">dxl</param>
        <param name="ID">27</param>
        <command_interface name="Goal Position"/>
        <state_interface name="Present Position"/>
        <state_interface name="Present Velocity"/>
        <!--<state_interface name="Present Current"/> -->
        <param name="Operating Mode">3</param>
        <param name="Profile Velocity">100</param>
        <param name="Profile Acceleration">40</param>
        <param name="Position P Gain">800</param>
        <param name="Position I Gain">100</param>
        <param name="Position D Gain">100</param>
        <param name="Return Delay Time">0</param>
        <param name="Drive Mode">0</param>
      </gpio>
      
   
      </xacro:unless>
    </ros2_control>
  </xacro:macro>

</robot>
